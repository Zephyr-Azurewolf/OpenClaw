#!/bin/bash
# ==============================================================================
# OpenClaw Bootstrap Script (Secure Secret Injection to Service Runtime)
# ==============================================================================
# Purpose: Fetches API secrets from a secure vault and mounts them into a 
# volatile RAM directory to prevent sensitive data from touching persistent storage.
#
# REQUIREMENT: The RAM_DIR path must be configured in the [Service] block 
# of your systemd unit file using: RuntimeDirectory=your-directory-name
# ==============================================================================

# --- 1. CONFIGURATION ---
# Replace these with your environment-specific paths
APP_DIR="/home/user/.openclaw/agents/main/agent"
RAM_DIR="/run/openclaw-vault" 
VAULT_NAME="your-vault-name"
SECRET_NAME="your-api-key-secret"

# --- 2. FETCH & WRITE TO RAM ---
# Fetching the secret from a secure provider (e.g., Azure Key Vault)
SECRET_VAL=$(az keyvault secret show --name "$SECRET_NAME" --vault-name "$VAULT_NAME" --query value -o tsv)
AUTH_PAYLOAD="{\"openrouter\": {\"type\": \"api_key\", \"key\": \"$SECRET_VAL\", \"apiKey\": \"$SECRET_VAL\"}}"

# Write the payload strictly to volatile memory
echo "$AUTH_PAYLOAD" > "$RAM_DIR/auth-profiles.json"

# --- 3. SECURE BIND MOUNT ---
# Create an empty anchor on the persistent disk to serve as the mount point
touch "$APP_DIR/auth-profiles.json"

# Overlay the RAM-resident file onto the SSD path
# No physical data is written to the persistent disk; it exists only in RAM
sudo mount --bind "$RAM_DIR/auth-profiles.json" "$APP_DIR/auth-profiles.json"

# Export the key to the local environment and scrub the temporary variable
export OPENROUTER_API_KEY="$SECRET_VAL"
unset SECRET_VAL

echo "Architecture Stabilized. Secrets injected into volatile RAM overlay."

# --- 4. THE HANDOVER ---
# 'exec' replaces the bash process with the application process directly, 
# inheriting the secure environment without leaving a shell behind.
exec /usr/bin/node /path/to/openclaw gateway
