#!/bin/bash

# --- 1. CONFIG ---
AGENT_DIR="${HOME}/.openclaw/agents/main/agent"

# --- 2. THE CLEANUP & MOUNT ---
# Terminate existing OpenClaw instances and clear previous mounts
pkill -f openclaw
sudo umount -l "$AGENT_DIR" 2>/dev/null

# Create a RAM disk (tmpfs) to ensure keys never hit the physical disk
mkdir -p "$AGENT_DIR"
sudo mount -t tmpfs -o size=5M tmpfs "$AGENT_DIR"
sudo chown -R $(whoami):$(whoami) "$AGENT_DIR"

# --- 3. AUTH INJECTION ---
# Replace with your secret management provider (e.g., local env, vault, or sops)
# Placeholder logic for secret retrieval:
SECRET_KEY="${OPENROUTER_API_KEY}" 

if [ -z "$SECRET_KEY" ]; then
    echo "Error: API Key not found in environment."
    exit 1
fi

AUTH_PAYLOAD="{\"openrouter\": {\"type\": \"api_key\", \"key\": \"$SECRET_KEY\", \"apiKey\": \"$SECRET_KEY\"}}"

# Write auth profiles directly to the RAM disk
echo "$AUTH_PAYLOAD" > "$AGENT_DIR/auth-profiles.json"
echo "$AUTH_PAYLOAD" > "$AGENT_DIR/auth.json"

echo "Security layer initialized: RAM disk mounted at $AGENT_DIR"

# --- 4. LAUNCH ---
export OPENROUTER_API_KEY="$SECRET_KEY"
# Clear sensitive variable before launch
unset SECRET_KEY

echo "Launching OpenClaw gateway..."
openclaw gateway
